# -----------------------------
# global env/log/cache
# -----------------------------
.env
.venv/
logs/
*.log
__pycache__/
pycache/
*.py[cod]
*.pyc.*

# -----------------------------
# local secrets / runtime files
# -----------------------------
credgcp.json
actions-runner/
pipelines/*/evaluation/history/*.tmp.json

# -----------------------------
# web_app local runtime content
# -----------------------------
web_app/.env
web_app/.venv/
web_app/__pycache__/
web_app/*.pyc
web_app/*.log
web_app/github_app_private_key.pem
web_app/generated_dags/
web_app/

# -----------------------------
# DAG folders
# -----------------------------
# ignore local generated DAGs

web_app/generated_dags/

# ignore repo dags by default, then allow deployment DAG .py files

!dags/
!dags/*.py
