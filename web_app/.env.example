APP_HOST=0.0.0.0
APP_PORT=8000
FLASK_DEBUG=0
APP_ADMIN_USERNAME=admin
APP_ADMIN_PASSWORD=change-me-admin-password
FLASK_SECRET_KEY=change-me

AZURE_CLIENT_ID=
AZURE_TENANT_ID=
AZURE_CLIENT_SECRET=
AZURE_REDIRECT_URI=http://localhost:8000/auth/callback

# Airflow API + DAG sync paths
# In Docker Compose, use Airflow service DNS name instead of localhost.
AIRFLOW_API_BASE_URL=http://airflow-apiserver:8080
AIRFLOW_API_USERNAME=airflow
AIRFLOW_API_PASSWORD=airflow
AIRFLOW_API_VERIFY_TLS=0
AIRFLOW_API_TIMEOUT_SECONDS=30
AIRFLOW_DAGS_DIR=/opt/airflow/dags
DAG_READY_POLL_TIMEOUT_SECONDS=600
DAG_READY_POLL_INTERVAL_SECONDS=5
DAG_RUN_POLL_TIMEOUT_SECONDS=1800
DAG_RUN_POLL_INTERVAL_SECONDS=5

# Optional: persistent app storage paths (recommended in Docker Compose)
GENERATED_DAGS_DIR=/opt/web_app_data/generated_dags
SAVED_PIPELINES_DIR=/opt/web_app_data/saved_pipelines
LOCAL_UPLOAD_STAGING_DIR=/opt/web_app_data/tmp_uploads
USERS_STORE_FILE=/opt/web_app_data/users_store.json
REQUESTS_STORE_FILE=/opt/web_app_data/requests_store.json
PIPELINE_VERSIONS_STORE_FILE=/opt/web_app_data/pipeline_versions_store.json
GCP_CONNECTIONS_STORE_FILE=/opt/web_app_data/gcp_connections_store.json
DAG_PUBLISH_STORE_FILE=/opt/web_app_data/dag_publish_store.json
USERS_FILE=/opt/web_app_data/users.json
GCP_SERVICE_ACCOUNT_HOST_FILE=/opt/web_app_data/credgcp.json

# GitHub App (org-owned, server-to-server)
GITHUB_APP_ID=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_PRIVATE_KEY_PATH=github_app_private_key.pem
# Optional alternative to *_PATH:
# GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
GITHUB_APP_INSTALLATION_ID=
GITHUB_OWNER=
GITHUB_REPO=
GITHUB_BASE_BRANCH=main
GITHUB_DAGS_REPO_DIR=airflow/dags
GITHUB_API_BASE_URL=https://api.github.com
GITHUB_WEBHOOK_SECRET=
# suffix | reuse_or_suffix
GITHUB_BRANCH_COLLISION_STRATEGY=suffix
