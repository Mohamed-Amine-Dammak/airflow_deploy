@task(task_id={{ task_id | pyrepr }})
def {{ function_name }}():
    local_file_path = {{ config.get("local_file_path") | pyrepr }}
    local_file_path_container = {{ config.get("local_file_path_container") | pyrepr }}
    local_file_paths = {{ config.get("local_file_paths", []) | pyrepr }}
    container_name = {{ config.get("container_name") | pyrepr }}
    upload_mode = {{ config.get("upload_mode", "single") | pyrepr }}
    blob_name = {{ config.get("blob_name") | pyrepr }}
    blob_prefix = {{ config.get("blob_prefix", "") | pyrepr }}
    create_container = {{ config.get("create_container", True) | pyrepr }}
    effective_local_file_path = str(local_file_path_container or local_file_path or "").strip()

    if upload_mode == "multiple":
        files = [str(item).strip() for item in (local_file_paths or []) if str(item).strip()]
        if not files:
            raise AirflowException("Azure multiple upload requires local_file_paths.")
        prefix = str(blob_prefix or "").strip().strip("/")

        uploaded_blobs = []
        for idx, one_file in enumerate(files):
            if not os.path.exists(one_file):
                raise AirflowException(f"Local file does not exist for Azure upload: {one_file}")
            file_name = os.path.basename(one_file)
            target_blob = f"{prefix}/{file_name}" if prefix else file_name
            LocalFilesystemToWasbOperator(
                task_id={{ (task_id ~ "_inner_upload_") | pyrepr }} + str(idx + 1),
                wasb_conn_id="wasb_default",
                file_path=one_file,
                container_name=container_name,
                blob_name=target_blob,
                create_container=bool(create_container),
            ).execute(context={})
            uploaded_blobs.append(target_blob)

        return {
            "uploaded": True,
            "upload_mode": "multiple",
            "uploaded_count": len(uploaded_blobs),
            "uploaded_blobs": uploaded_blobs,
            "container_name": container_name,
            "create_container": bool(create_container),
        }

    if not os.path.exists(effective_local_file_path):
        raise AirflowException(f"Local file does not exist for Azure upload: {effective_local_file_path}")
    if not blob_name:
        raise AirflowException("Azure blob_name is required for single upload.")

    LocalFilesystemToWasbOperator(
        task_id={{ (task_id ~ "_inner_upload") | pyrepr }},
        wasb_conn_id="wasb_default",
        file_path=effective_local_file_path,
        container_name=container_name,
        blob_name=blob_name,
        create_container=bool(create_container),
    ).execute(context={})

    return {
        "uploaded": True,
        "upload_mode": "single",
        "blob_name": blob_name,
        "container_name": container_name,
        "create_container": bool(create_container),
    }


{{ task_var }} = {{ function_name }}()
