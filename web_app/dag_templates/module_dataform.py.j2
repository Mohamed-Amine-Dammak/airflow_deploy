@task(task_id={{ task_id | pyrepr }})
def {{ function_name }}():
    project_id = {{ config.get("project_id") | pyrepr }}
    project_ids = {{ config.get("project_ids", []) | pyrepr }}
    if not project_id and project_ids:
        project_id = project_ids[0]
    if not project_id:
        raise AirflowException("Dataform project id is required.")
    region = {{ config.get("region") | pyrepr }}
    repository = {{ config.get("repository") | pyrepr }}
    compilation_id = {{ config.get("compilation_id") | pyrepr }}
    gcp_connection_id = {{ config.get("gcp_connection_id", "") | pyrepr }}
    service_account_file = {{ config.get("service_account_file") | pyrepr }}

    def _resolve_service_account_file(path, connection_id):
        safe_path = str(path or "").strip()
        if safe_path and os.path.exists(safe_path):
            return safe_path

        conn_id = str(connection_id or "").strip()
        if not conn_id:
            if safe_path:
                raise AirflowException(f"Service account file not found: {safe_path}")
            raise AirflowException("dataform.gcp_connection_id or dataform.service_account_file is required.")

        try:
            conn = BaseHook.get_connection(conn_id)
        except Exception as exc:
            raise AirflowException(f"Unable to load Airflow connection '{conn_id}': {exc}") from exc

        extra = conn.extra_dejson or {}
        key_path = str(
            extra.get("key_path")
            or extra.get("keyfile_path")
            or extra.get("extra__google_cloud_platform__key_path")
            or extra.get("extra__google_cloud_platform__keyfile_path")
            or ""
        ).strip()
        if key_path:
            if os.path.exists(key_path):
                return key_path
            raise AirflowException(f"GCP connection '{conn_id}' key path not found: {key_path}")

        key_dict = (
            extra.get("keyfile_dict")
            or extra.get("extra__google_cloud_platform__keyfile_dict")
            or None
        )
        if isinstance(key_dict, str):
            try:
                key_dict = json.loads(key_dict)
            except Exception as exc:
                raise AirflowException(
                    f"GCP connection '{conn_id}' has invalid keyfile_dict JSON."
                ) from exc
        if isinstance(key_dict, dict) and key_dict:
            tmp_path = os.path.join("/tmp", f"gcp_sa_{conn_id}_{int(time.time() * 1000)}.json")
            with open(tmp_path, "w", encoding="utf-8") as handle:
                json.dump(key_dict, handle)
            return tmp_path

        raise AirflowException(
            f"GCP connection '{conn_id}' is missing key credentials in extras (key_path/keyfile_dict)."
        )

    service_account_file = _resolve_service_account_file(service_account_file, gcp_connection_id)

    credentials = service_account.Credentials.from_service_account_file(
        service_account_file,
        scopes=["https://www.googleapis.com/auth/cloud-platform"],
    )
    credentials.refresh(Request())

    with open(service_account_file, encoding="utf-8") as handle:
        service_account_email = json.load(handle)["client_email"]

    base_repo = f"projects/{project_id}/locations/{region}/repositories/{repository}"
    headers = {
        "Authorization": f"Bearer {credentials.token}",
        "Content-Type": "application/json",
    }

    if not compilation_id:
        latest_compilation_resp = requests.get(
            f"https://dataform.googleapis.com/v1/{base_repo}/compilationResults",
            headers=headers,
            params={"pageSize": 1},
            timeout=60,
        )
        if latest_compilation_resp.status_code != 200:
            raise AirflowException(
                "Dataform compilation_id is not provided and latest compilation lookup failed: "
                f"{latest_compilation_resp.status_code} {latest_compilation_resp.text}"
            )
        latest_results = latest_compilation_resp.json().get("compilationResults", [])
        if not latest_results:
            raise AirflowException("No Dataform compilation results found. Provide compilation_id.")
        full_name = latest_results[0]["name"]
        compilation_id = full_name.split("/")[-1]

    body = {
        "compilationResult": f"{base_repo}/compilationResults/{compilation_id}",
        "invocationConfig": {
            "serviceAccount": service_account_email,
        },
    }
    url = f"https://dataform.googleapis.com/v1/{base_repo}/workflowInvocations"
    create_resp = requests.post(url, headers=headers, json=body, timeout=60)
    if create_resp.status_code != 200:
        raise AirflowException(f"Dataform invocation failed: {create_resp.status_code} {create_resp.text}")

    invocation_name = create_resp.json().get("name")
    if not invocation_name:
        raise AirflowException(f"Dataform invocation missing response name: {create_resp.text}")

    status_url = f"https://dataform.googleapis.com/v1/{invocation_name}"
    while True:
        status_resp = requests.get(status_url, headers=headers, timeout=60)
        if status_resp.status_code != 200:
            raise AirflowException(f"Dataform status polling failed: {status_resp.status_code} {status_resp.text}")
        state = status_resp.json().get("state")
        print(f"Dataform state={state} invocation={invocation_name}")
        if state == "SUCCEEDED":
            break
        if state in {"FAILED", "CANCELLED", "CANCELING"}:
            raise AirflowException(f"Dataform invocation failed with state={state}")
        time.sleep(15)

    return {"invocation_name": invocation_name, "state": "SUCCEEDED"}


{{ task_var }} = {{ function_name }}()
