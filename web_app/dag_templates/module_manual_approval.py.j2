@task(task_id={{ task_id | pyrepr }})
def {{ function_name }}(**context):
    approval_conf_key = str({{ config.get("approval_conf_key", "manual_approved") | pyrepr }})
    approval_expected_value = str({{ config.get("approval_expected_value", "true") | pyrepr }}).strip().lower()

    dag_run = context.get("dag_run")
    dag_conf = getattr(dag_run, "conf", {}) if dag_run else {}
    if not isinstance(dag_conf, dict):
        dag_conf = {}

    raw_value = dag_conf.get(approval_conf_key)
    normalized_value = str(raw_value).strip().lower()
    approved = normalized_value == approval_expected_value

    if not approved:
        raise AirflowException(
            f"Manual approval gate blocked. Run DAG with conf key '{approval_conf_key}' "
            f"set to '{approval_expected_value}'. Current value: {raw_value!r}"
        )

    return {"approved": True, "approval_conf_key": approval_conf_key, "approval_value": raw_value}


{{ task_var }} = {{ function_name }}()
