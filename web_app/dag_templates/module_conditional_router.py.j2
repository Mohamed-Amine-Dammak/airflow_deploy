router_target_task_ids_{{ function_name }} = {
{% for target in router_target_mappings %}
    {{ target.node_id | pyrepr }}: {{ target.target_task_id_literal | pyrepr }},
{% endfor %}
}

router_source_task_ids_{{ function_name }} = {
{% for source in router_source_mappings %}
    {{ source.node_id | pyrepr }}: {{ source.source_task_id_literal | pyrepr }},
{% endfor %}
}


def _resolve_router_input_{{ function_name }}(source: str, context: dict):
    source_key = str(source or "").strip()
    if source_key.startswith("xcom_node:"):
        node_ref = source_key.split(":", 1)[1].strip()
        node_id, sep, dict_key = node_ref.partition(".")
        resolved_task_id = router_source_task_ids_{{ function_name }}.get(node_id, "")
        if not resolved_task_id:
            raise AirflowException(
                f"conditional_router unknown xcom_node reference '{node_id}'. "
                f"Known node ids: {sorted(router_source_task_ids_{{ function_name }}.keys())}"
            )
        pulled = context["ti"].xcom_pull(task_ids=resolved_task_id)
        if sep and dict_key and isinstance(pulled, dict):
            return pulled.get(dict_key)
        return pulled

    if source_key.startswith("xcom:"):
        task_ref = source_key.split(":", 1)[1].strip()
        source_task_id, sep, dict_key = task_ref.partition(".")
        if not source_task_id:
            raise AirflowException("conditional_router input_source xcom reference is empty.")
        pulled = context["ti"].xcom_pull(task_ids=source_task_id)
        if sep and dict_key and isinstance(pulled, dict):
            return pulled.get(dict_key)
        return pulled

    dag_run = context.get("dag_run")
    dag_conf = getattr(dag_run, "conf", {}) if dag_run else {}
    if isinstance(dag_conf, dict) and source_key in dag_conf:
        return dag_conf.get(source_key)

    return source_key


def _router_rule_match_{{ function_name }}(match_type: str, candidate: str, expected: str) -> bool:
    if match_type == "starts_with":
        return candidate.startswith(expected)
    if match_type == "contains":
        return expected in candidate
    if match_type == "equals":
        return candidate == expected
    if match_type == "regex":
        return re.search(expected, candidate) is not None
    return False


def _route_callable_{{ function_name }}(**context):
    input_source = {{ config.get("input_source") | pyrepr }}
    rules = {{ config.get("rules", []) | pyrepr }}
    router_input = _resolve_router_input_{{ function_name }}(input_source, context)
    candidate = "" if router_input is None else str(router_input)

    for rule in rules:
        match_type = str(rule.get("match_type", "")).strip().lower()
        expected = str(rule.get("value", ""))
        target_node_id = str(rule.get("target_branch_node_id", "")).strip()
        target_task_id = router_target_task_ids_{{ function_name }}.get(target_node_id)
        if not target_task_id:
            continue
        if _router_rule_match_{{ function_name }}(match_type, candidate, expected):
            print(
                f"Router {{ task_id }} matched rule match_type={match_type}, value={expected}, "
                f"target_node_id={target_node_id}, target_task_id={target_task_id}"
            )
            return target_task_id

    raise AirflowException(
        f"Router {{ task_id }} found no matching rule for input_source={input_source}, value={candidate}."
    )


{{ task_var }} = BranchPythonOperator(
    task_id={{ task_id | pyrepr }},
    python_callable=_route_callable_{{ function_name }},
)
