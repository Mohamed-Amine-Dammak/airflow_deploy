@task(task_id={{ task_id | pyrepr }})
def {{ function_name }}():
    wasb_conn_id = {{ config.get("wasb_conn_id", "wasb_default") | pyrepr }}
    container_name = {{ config.get("container_name") | pyrepr }}
    delete_mode = {{ config.get("delete_mode", "single") | pyrepr }}
    delete_blob_name = {{ config.get("delete_blob_name") | pyrepr }}
    delete_prefix = {{ config.get("delete_prefix") | pyrepr }} or ""

    if delete_blob_name:
        delete_blob_name = str(delete_blob_name).lstrip("/")
    if delete_prefix:
        delete_prefix = str(delete_prefix).lstrip("/")

    hook = WasbHook(wasb_conn_id=wasb_conn_id)

    deleted_blobs = []
    if delete_mode == "single":
        if not delete_blob_name:
            raise AirflowException("Azure delete mode 'single' requires delete_blob_name.")
        hook.delete_file(container_name=container_name, blob_name=delete_blob_name)
        deleted_blobs.append(delete_blob_name)
    else:
        if not delete_prefix:
            raise AirflowException("Azure delete mode 'multiple' requires delete_prefix.")
        blobs = hook.get_blobs_list(container_name=container_name, prefix=delete_prefix) or []
        if not blobs:
            raise AirflowException(
                f"No Azure blobs found for delete criteria mode={delete_mode}, prefix='{delete_prefix}'."
            )

        for blob_name in blobs:
            hook.delete_file(container_name=container_name, blob_name=blob_name)
            deleted_blobs.append(blob_name)

    return {
        "deleted": True,
        "delete_mode": delete_mode,
        "deleted_count": len(deleted_blobs),
        "deleted_blobs": deleted_blobs,
        "container_name": container_name,
    }


{{ task_var }} = {{ function_name }}()
