@task(task_id={{ task_id | pyrepr }}, trigger_rule="all_done")
def {{ function_name }}(**context):
    min_success_count = int({{ config.get("min_success_count", 1) | pyrepr }})
    ti = context["ti"]
    dag_run = context.get("dag_run")
    upstream_task_ids = list(ti.task.upstream_task_ids)
    if not upstream_task_ids:
        raise AirflowException("quorum_join requires upstream branches.")
    if min_success_count <= 0:
        raise AirflowException("quorum_join.min_success_count must be > 0.")

    success_count = 0
    failed_count = 0
    state_by_task = {}
    for upstream_task_id in upstream_task_ids:
        upstream_ti = dag_run.get_task_instance(upstream_task_id) if dag_run else None
        state = str(getattr(upstream_ti, "state", "") or "").strip().lower()
        state_by_task[upstream_task_id] = state
        if state == "success":
            success_count += 1
        elif state in {"failed", "upstream_failed"}:
            failed_count += 1

    if success_count < min_success_count:
        raise AirflowException(
            f"Quorum not met. success_count={success_count}, required={min_success_count}, "
            f"failed_count={failed_count}, states={state_by_task}"
        )

    return {
        "quorum_met": True,
        "success_count": success_count,
        "required_success_count": min_success_count,
        "failed_count": failed_count,
        "upstream_states": state_by_task,
    }


{{ task_var }} = {{ function_name }}()
