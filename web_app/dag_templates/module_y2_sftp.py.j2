@task(task_id={{ task_id | pyrepr }})
def {{ function_name }}():
    folder_id_value = {{ config.get("folder_id_value") | pyrepr }}
    task_ids = {{ config.get("task_ids_value") | pyrepr }}
    export_file_glob = {{ config.get("export_file_glob") | pyrepr }}
    export_local_dir = {{ config.get("export_local_dir") | pyrepr }}
    remote_dir = {{ config.get("remote_dir") | pyrepr }}

    if not task_ids:
        raise AirflowException("y2 export_to_sftp requires at least one task id.")
    task_id_value = int(task_ids[0])

    conn = BaseHook.get_connection("cegid_y2")
    base_host = (conn.host or "").rstrip("/")
    username = conn.login
    password = conn.password or ""
    if not base_host or not username:
        raise AirflowException("cegid_y2 connection must include host/login.")

    from requests.auth import HTTPBasicAuth

    auth = HTTPBasicAuth(f"{folder_id_value}\\{username}", password)
    session = requests.Session()
    session.headers.update({"Accept": "application/json"})
    base_task_url = f"{base_host}/{folder_id_value}/api/scheduled-tasks/v1"

    local_path = Path(export_local_dir)
    if not local_path.exists():
        raise AirflowException(f"Y2 export local directory does not exist: {export_local_dir}")

    snapshot = {}
    for entry in local_path.iterdir():
        if entry.is_file() and fnmatch.fnmatch(entry.name, export_file_glob):
            snapshot[str(entry.resolve())] = entry.stat().st_mtime

    enable_resp = session.post(f"{base_task_url}/enable", auth=auth, params=[("ids", task_id_value)], timeout=60)
    if enable_resp.status_code != 200:
        raise AirflowException(f"Y2 enable failed for task={task_id_value}: {enable_resp.status_code} {enable_resp.text}")

    run_resp = session.post(f"{base_task_url}/run", auth=auth, params=[("ids", task_id_value)], timeout=60)
    if run_resp.status_code != 200:
        raise AirflowException(f"Y2 run failed for task={task_id_value}: {run_resp.status_code} {run_resp.text}")

    started_at = time.time()
    while True:
        poll_resp = session.get(
            f"{base_task_url}/{task_id_value}",
            auth=auth,
            params=[("fields", "Execution")],
            timeout=60,
        )
        if poll_resp.status_code != 200:
            raise AirflowException(
                f"Y2 monitor failed for task={task_id_value}: {poll_resp.status_code} {poll_resp.text}"
            )
        payload = poll_resp.json()
        in_progress = bool(payload.get("inProgress"))
        execution = payload.get("execution") or {}
        last_execution = (execution.get("lastExecution") or {}).get("date")
        if last_execution and not in_progress:
            break
        if time.time() - started_at > 600:
            raise AirflowException(f"Y2 monitor timeout for task={task_id_value}")
        time.sleep(15)

    selected_file: Path | None = None
    wait_started = time.time()
    while True:
        candidates = []
        for entry in local_path.iterdir():
            if not entry.is_file() or not fnmatch.fnmatch(entry.name, export_file_glob):
                continue
            entry_key = str(entry.resolve())
            previous_mtime = snapshot.get(entry_key)
            if previous_mtime is None or entry.stat().st_mtime > previous_mtime:
                candidates.append(entry)
        if candidates:
            candidates.sort(key=lambda item: item.stat().st_mtime, reverse=True)
            selected_file = candidates[0]
            break
        if time.time() - wait_started > 300:
            raise AirflowException(
                f"No new/updated Y2 export file found in '{export_local_dir}' matching '{export_file_glob}'."
            )
        time.sleep(10)

    sftp_hook = SFTPHook(ssh_conn_id="sftp")
    remote_path = f"{remote_dir.rstrip('/')}/{selected_file.name}"
    sftp_hook.store_file(remote_full_path=remote_path, local_full_path=str(selected_file.resolve()))

    return {"local_file": str(selected_file.resolve()), "remote_path": remote_path, "uploaded": True}


{{ task_var }} = {{ function_name }}()
