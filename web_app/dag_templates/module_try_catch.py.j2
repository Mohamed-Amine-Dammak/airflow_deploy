router_target_task_ids_{{ function_name }} = {
{% for target in router_target_mappings %}
    {{ target.node_id | pyrepr }}: {{ target.target_task_id_literal | pyrepr }},
{% endfor %}
}


def _route_callable_{{ function_name }}(**context):
    success_branch_node_id = str({{ config.get("success_branch_node_id", "") | pyrepr }}).strip()
    catch_branch_node_id = str({{ config.get("catch_branch_node_id", "") | pyrepr }}).strip()

    success_task_id = router_target_task_ids_{{ function_name }}.get(success_branch_node_id)
    catch_task_id = router_target_task_ids_{{ function_name }}.get(catch_branch_node_id)
    if not success_task_id or not catch_task_id:
        raise AirflowException(
            f"try_catch has invalid branch targets success='{success_branch_node_id}', "
            f"catch='{catch_branch_node_id}'."
        )

    ti = context["ti"]
    dag_run = context.get("dag_run")
    upstream_task_ids = list(ti.task.upstream_task_ids)
    upstream_states = {}
    for upstream_task_id in upstream_task_ids:
        upstream_ti = dag_run.get_task_instance(upstream_task_id) if dag_run else None
        state = str(getattr(upstream_ti, "state", "") or "").strip().lower()
        upstream_states[upstream_task_id] = state

    has_failure = any(state in {"failed", "upstream_failed"} for state in upstream_states.values())
    if has_failure:
        print(f"try_catch {{ task_id }} routing to catch branch. upstream_states={upstream_states}")
        return catch_task_id

    print(f"try_catch {{ task_id }} routing to success branch. upstream_states={upstream_states}")
    return success_task_id


{{ task_var }} = BranchPythonOperator(
    task_id={{ task_id | pyrepr }},
    trigger_rule="all_done",
    python_callable=_route_callable_{{ function_name }},
)
