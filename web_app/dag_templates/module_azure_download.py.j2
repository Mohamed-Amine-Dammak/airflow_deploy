@task(task_id={{ task_id | pyrepr }})
def {{ function_name }}():
    wasb_conn_id = {{ config.get("wasb_conn_id", "wasb_default") | pyrepr }}
    container_name = {{ config.get("container_name") | pyrepr }}
    download_mode = {{ config.get("download_mode", "single") | pyrepr }}
    file_name = {{ config.get("file_name") | pyrepr }}
    file_prefix = {{ config.get("file_prefix") | pyrepr }} or ""
    local_dir_download = {{ config.get("local_dir_download") | pyrepr }}
    default_download_dir = "/opt/airflow/local_downloads/azure"

    if file_name:
        file_name = str(file_name).strip().lstrip("/")
    if file_prefix:
        file_prefix = str(file_prefix).strip().lstrip("/")

    hook = WasbHook(wasb_conn_id=wasb_conn_id)

    def _blob_name(item):
        # WasbHook may return either blob-name strings or blob objects.
        if hasattr(item, "name"):
            return str(getattr(item, "name") or "").strip()
        if isinstance(item, dict) and item.get("name"):
            return str(item.get("name") or "").strip()
        return str(item or "").strip()

    def _is_writable_directory(path_value):
        try:
            if not path_value:
                return False
            os.makedirs(path_value, exist_ok=True)
            probe = os.path.join(path_value, ".write_test")
            with open(probe, "w", encoding="utf-8") as fh:
                fh.write("ok")
            os.remove(probe)
            return True
        except Exception:
            return False

    requested_download_dir = str(local_dir_download or "").strip()
    if _is_writable_directory(requested_download_dir):
        local_dir_download = requested_download_dir
    elif _is_writable_directory(default_download_dir):
        local_dir_download = default_download_dir
    else:
        raise AirflowException(
            f"Azure download destination is not writable: '{requested_download_dir or '(empty)'}'. "
            f"Also failed fallback '{default_download_dir}'."
        )

    if download_mode == "single":
        if not file_name:
            raise AirflowException("Azure download mode 'single' requires file_name.")
        query = str(file_name).lstrip("/")
        query_lower = query.lower()
        is_prefix_mode = query.endswith("_")
        all_blobs_raw = hook.get_blobs_list(container_name=container_name, prefix="") or []
        all_blobs = [_blob_name(item) for item in all_blobs_raw if _blob_name(item)]
        if is_prefix_mode:
            matching_blobs = [
                blob_name
                for blob_name in all_blobs
                if os.path.basename(str(blob_name).rstrip("/")).lower().startswith(query_lower)
                or str(blob_name).lower().startswith(query_lower)
            ]
        else:
            matching_blobs = [
                blob_name
                for blob_name in all_blobs
                if os.path.basename(str(blob_name).rstrip("/")).lower() == query_lower
                or str(blob_name).rstrip("/").lower() == query_lower
            ]

        if not is_prefix_mode and len(matching_blobs) > 1:
            raise AirflowException(
                f"Multiple blobs matched exact name '{query}'. Use folder path to disambiguate. Matches={matching_blobs}"
            )
    else:
        if not file_prefix:
            raise AirflowException("Azure download mode 'multiple' requires file_prefix.")
        query_prefix = str(file_prefix).strip().lstrip("/")
        query_prefix_lower = query_prefix.lower()
        # First strategy: ask Azure directly with the provided prefix.
        direct_prefixed_raw = hook.get_blobs_list(container_name=container_name, prefix=query_prefix) or []
        direct_prefixed = [_blob_name(item) for item in direct_prefixed_raw if _blob_name(item)]

        # Fallback strategy: list all and match by full path or basename.
        all_blobs_raw = hook.get_blobs_list(container_name=container_name, prefix="") or []
        all_blobs = [_blob_name(item) for item in all_blobs_raw if _blob_name(item)]
        basename_prefix = os.path.basename(query_prefix).lower()
        fallback_matches = [
            blob_name
            for blob_name in all_blobs
            if str(blob_name).lower().startswith(query_prefix_lower)
            or os.path.basename(str(blob_name).rstrip("/")).lower().startswith(basename_prefix)
        ]

        # Keep unique order: direct matches first, then fallback extras.
        matching_blobs = []
        for candidate in direct_prefixed + fallback_matches:
            if candidate and candidate not in matching_blobs:
                matching_blobs.append(candidate)

    if not matching_blobs:
        if download_mode == "single":
            raise AirflowException(
                f"No Azure blob matched file_name '{query}' in container '{container_name}'. "
                "Use trailing '_' for prefix match or full path for exact match."
            )
        raise AirflowException(
            f"No Azure blobs matched download criteria mode={download_mode}, prefix='{file_prefix}'. "
            f"Sample available blobs={all_blobs[:10]}"
        )

    downloaded = []
    for blob_name in matching_blobs:
        filename = os.path.basename(blob_name.rstrip("/"))
        if not filename:
            continue
        local_file_path = os.path.join(local_dir_download, filename)
        hook.get_file(file_path=local_file_path, container_name=container_name, blob_name=blob_name)
        downloaded.append({"blob_name": blob_name, "local_path": local_file_path})

    return {"downloaded_files": downloaded}


{{ task_var }} = {{ function_name }}()
