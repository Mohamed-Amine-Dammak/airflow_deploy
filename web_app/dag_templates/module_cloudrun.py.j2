@task(task_id={{ task_id | pyrepr }})
def {{ function_name }}():
    cloud_run_url = {{ config.get("url") | pyrepr }}
    gcp_connection_id = {{ config.get("gcp_connection_id", "") | pyrepr }}
    service_account_file = {{ config.get("service_account_file") | pyrepr }}
    payload = {{ config.get("payload") | pyrepr }}

    def _resolve_service_account_file(path, connection_id):
        safe_path = str(path or "").strip()
        if safe_path and os.path.exists(safe_path):
            return safe_path

        conn_id = str(connection_id or "").strip()
        if not conn_id:
            if safe_path:
                raise AirflowException(f"Service account file not found: {safe_path}")
            raise AirflowException("cloudrun.gcp_connection_id or cloudrun.service_account_file is required.")

        try:
            conn = BaseHook.get_connection(conn_id)
        except Exception as exc:
            raise AirflowException(f"Unable to load Airflow connection '{conn_id}': {exc}") from exc

        extra = conn.extra_dejson or {}

        key_path = str(
            extra.get("key_path")
            or extra.get("keyfile_path")
            or extra.get("extra__google_cloud_platform__key_path")
            or extra.get("extra__google_cloud_platform__keyfile_path")
            or ""
        ).strip()
        if key_path:
            if os.path.exists(key_path):
                return key_path
            raise AirflowException(f"GCP connection '{conn_id}' key path not found: {key_path}")

        key_dict = (
            extra.get("keyfile_dict")
            or extra.get("extra__google_cloud_platform__keyfile_dict")
            or None
        )
        if isinstance(key_dict, str):
            try:
                key_dict = json.loads(key_dict)
            except Exception as exc:
                raise AirflowException(
                    f"GCP connection '{conn_id}' has invalid keyfile_dict JSON."
                ) from exc
        if isinstance(key_dict, dict) and key_dict:
            tmp_path = os.path.join("/tmp", f"gcp_sa_{conn_id}_{int(time.time() * 1000)}.json")
            with open(tmp_path, "w", encoding="utf-8") as handle:
                json.dump(key_dict, handle)
            return tmp_path

        raise AirflowException(
            f"GCP connection '{conn_id}' is missing key credentials in extras (key_path/keyfile_dict)."
        )

    service_account_file = _resolve_service_account_file(service_account_file, gcp_connection_id)

    credentials = service_account.IDTokenCredentials.from_service_account_file(
        service_account_file,
        target_audience=cloud_run_url,
    )
    credentials.refresh(Request())

    headers = {
        "Authorization": f"Bearer {credentials.token}",
        "Content-Type": "application/json",
        "User-Agent": "Airflow",
    }

    response = requests.post(
        cloud_run_url,
        headers=headers,
        data=json.dumps(payload),
        timeout=300,
    )

    if response.status_code not in (200, 201, 202):
        raise AirflowException(
            f"Cloud Run call failed. status={response.status_code}, body={response.text}, url={cloud_run_url}"
        )

    return {
        "cloud_run_url": cloud_run_url,
        "status_code": response.status_code,
        "response_text": response.text,
    }


{{ task_var }} = {{ function_name }}()
