{{ task_var }} = EmptyOperator(
    task_id={{ task_id | pyrepr }},
    retries=int({{ config.get("retries", 3) | pyrepr }}),
    retry_delay=timedelta(minutes=int({{ config.get("retry_delay_minutes", 5) | pyrepr }})),
    retry_exponential_backoff={{ config.get("retry_exponential_backoff", False) | pyrepr }},
)
