{
  "pipeline": {
    "dag_id": "demo_n8n_cloudrun_dataform_powerbi",
    "description": "Demo sequential orchestration pipeline",
    "schedule": null,
    "schedule_mode": "manual",
    "schedule_preset": "",
    "schedule_cron": "",
    "interval_value": "",
    "interval_unit": "minutes",
    "event_source": "",
    "custom_schedule_text": "",
    "retries": 3,
    "retry_delay_minutes": 5,
    "alert_emails": [
      "test@example.com"
    ],
    "alert_mode": "both",
    "tags": [
      "demo",
      "orchestration"
    ],
    "output_filename": "demo_n8n_cloudrun_dataform_powerbi.py"
  },
  "nodes": [
    {
      "id": "node_1",
      "type": "n8n",
      "label": "Trigger n8n workflow",
      "config": {
        "workflow_name": "my_workflow",
        "http_method": "GET",
        "query_params": {
          "env": "prod"
        },
        "use_test_webhook": true
      }
    },
    {
      "id": "node_2",
      "type": "cloudrun",
      "label": "Run Cloud Run",
      "config": {
        "url": "https://example-cloudrun-url.run.app/process",
        "service_account_file": "C:/keys/sa-cloudrun.json",
        "payload": {
          "dataset": "raw",
          "integration_source": "n8n"
        }
      }
    },
    {
      "id": "node_3",
      "type": "dataform",
      "label": "Run Dataform",
      "config": {
        "project_id": "os-dpf-airflow-prj-dev",
        "region": "europe-west1",
        "repository": "airflow-dataform",
        "service_account_file": "C:/keys/sa-dataform.json",
        "compilation_id": "",
        "dataform_tags": [
          "STG",
          "DH",
          "DW"
        ]
      }
    },
    {
      "id": "node_4",
      "type": "powerbi",
      "label": "Refresh Power BI dataset",
      "config": {
        "workspace_id": "workspace-guid",
        "dataset_id": "dataset-guid"
      }
    }
  ],
  "edges": [
    {
      "source": "node_1",
      "target": "node_2"
    },
    {
      "source": "node_2",
      "target": "node_3"
    },
    {
      "source": "node_3",
      "target": "node_4"
    }
  ]
}
