{
  "pipeline": {
    "dag_id": "my_pipeline_sensor",
    "description": "Sequential orchestration pipeline",
    "schedule": null,
    "schedule_mode": "manual",
    "schedule_preset": "",
    "schedule_cron": "",
    "interval_value": "",
    "interval_unit": "minutes",
    "event_source": "",
    "custom_schedule_text": "",
    "retries": 3,
    "retry_delay_minutes": 5,
    "alert_emails": [],
    "alert_mode": "both",
    "tags": [
      "demo",
      "orchestration"
    ],
    "output_filename": "my_pipeline_sensor.py"
  },
  "nodes": [
    {
      "id": "node_1",
      "type": "azure_blob_sensor",
      "label": "Azure Blob Sensor 1",
      "config": {
        "container_name": "my-container",
        "poke_interval": 30,
        "prefix": "uploads/CUSTOMER_",
        "timeout": 600,
        "wasb_conn_id": "wasb_default"
      }
    },
    {
      "id": "node_2",
      "type": "azure",
      "label": "Azure Download 2",
      "config": {
        "action": "download",
        "container_name": "my-container",
        "download_mode": "multiple",
        "file_extension": ".csv",
        "file_name": "",
        "file_prefix": "uploads/CUSTOMER_",
        "local_dir_download": "/opt/airflow/dags/downloads"
      }
    }
  ],
  "edges": [
    {
      "source": "node_1",
      "target": "node_2"
    }
  ]
}