{
  "pipeline": {
    "dag_id": "wave1_simple_test",
    "description": "Simple test pipeline using Delay, If/Else, Timeout Guard, Manual Approval, and Switch Router.",
    "schedule": null,
    "schedule_mode": "manual",
    "catchup": false,
    "schedule_preset": "",
    "schedule_cron": "",
    "interval_value": "",
    "interval_unit": "minutes",
    "event_source": "",
    "custom_schedule_text": "",
    "retries": 1,
    "retry_delay_minutes": 2,
    "alert_emails": [
      "qa@example.com"
    ],
    "alert_mode": "both",
    "tags": [
      "wave1",
      "control-modules"
    ],
    "output_filename": "wave1_simple_test.py"
  },
  "nodes": [
    {
      "id": "node_1",
      "type": "delay",
      "label": "Delay 1 min",
      "x": 60,
      "y": 90,
      "config": {
        "delay_minutes": 1
      }
    },
    {
      "id": "node_2",
      "type": "if_else_router",
      "label": "If approved flag",
      "x": 350,
      "y": 90,
      "config": {
        "expected_value": "true",
        "false_branch_node_id": "node_4",
        "input_source": "approval_path",
        "match_type": "equals",
        "true_branch_node_id": "node_3"
      }
    },
    {
      "id": "node_3",
      "type": "manual_approval",
      "label": "Manual Approval",
      "x": 640,
      "y": 90,
      "config": {
        "approval_conf_key": "manual_approved",
        "approval_expected_value": "true"
      }
    },
    {
      "id": "node_4",
      "type": "timeout_guard",
      "label": "Timeout Guard 5m",
      "x": 640,
      "y": 270,
      "config": {
        "timeout_minutes": 5
      }
    },
    {
      "id": "node_5",
      "type": "parallel_join",
      "label": "Join after If/Else",
      "x": 930,
      "y": 90,
      "config": {
        "trigger_rule": "none_failed_min_one_success"
      }
    },
    {
      "id": "node_6",
      "type": "switch_router",
      "label": "Switch by route",
      "x": 1220,
      "y": 90,
      "config": {
        "cases": [
          {
            "match_type": "equals",
            "target_branch_node_id": "node_7",
            "value": "A"
          }
        ],
        "default_branch_node_id": "node_8",
        "input_source": "route"
      }
    },
    {
      "id": "node_7",
      "type": "n8n",
      "label": "n8n Path A",
      "x": 1510,
      "y": 90,
      "config": {
        "http_method": "GET",
        "use_test_webhook": true,
        "workflow_name": "test_airflow"
      }
    },
    {
      "id": "node_8",
      "type": "n8n",
      "label": "n8n Default",
      "x": 1510,
      "y": 270,
      "config": {
        "http_method": "GET",
        "use_test_webhook": true,
        "workflow_name": "test_airflow1"
      }
    },
    {
      "id": "node_9",
      "type": "parallel_join",
      "label": "Join after Switch",
      "x": 1800,
      "y": 90,
      "config": {
        "trigger_rule": "none_failed_min_one_success"
      }
    },
    {
      "id": "node_10",
      "type": "powerbi",
      "label": "Power BI Refresh",
      "x": 2090,
      "y": 90,
      "config": {
        "dataset_id": "b4350df9-bdcc-43fd-b458-1b1a4cb42831",
        "workspace_id": "5992b264-2c31-4087-9f57-3b3baa1e7b0d"
      }
    }
  ],
  "edges": [
    {
      "source": "node_1",
      "target": "node_2"
    },
    {
      "source": "node_2",
      "target": "node_3"
    },
    {
      "source": "node_2",
      "target": "node_4"
    },
    {
      "source": "node_3",
      "target": "node_5"
    },
    {
      "source": "node_4",
      "target": "node_5"
    },
    {
      "source": "node_5",
      "target": "node_6"
    },
    {
      "source": "node_6",
      "target": "node_7"
    },
    {
      "source": "node_6",
      "target": "node_8"
    },
    {
      "source": "node_7",
      "target": "node_9"
    },
    {
      "source": "node_8",
      "target": "node_9"
    },
    {
      "source": "node_9",
      "target": "node_10"
    }
  ]
}